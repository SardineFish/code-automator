{
  "name": "harness-engineering-skeleton",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A TypeScript scaffold for a GitHub App driven automation service.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/app/main.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "check:docs": "node scripts/check-docs.mjs",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check": "npm run check:docs && npm run check:architecture && npm run build && npm test",
    "plan:new": "node scripts/new-plan.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
