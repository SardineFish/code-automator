{
  "name": "github-agent-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A YAML-driven GitHub App webhook automation service.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/app/main.ts",
    "test": "node --import tsx --test $(find tests -name '*.test.ts' -print)",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:docs": "node scripts/check-docs.mjs",
    "check": "npm run check:docs && npm run check:architecture && npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "winston": "^3.18.3",
    "yaml": "^2.8.3"
  }
}
